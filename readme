--APP TOUCH
--Django + React + tailwind 
--Proyecto LDAP + BD

-

-- React
cd client   # carpeta donde está el React
npm install   # o yarn install  (instalas dependecias usadas en el proyecto)

-- Backend
cd client/backend 
npm install   # o yarn install  (instalas dependecias usadas en el proyecto para el backend de base de datos) 

-- En La Raiz Del Proyecto Django
python -m venv venv
pip install -r requirements.txt
pip freeze > requirements.txt

-- Host
vite.config.js -- aqui se deja autorizado el host para subir el proyecto a un servidor 


